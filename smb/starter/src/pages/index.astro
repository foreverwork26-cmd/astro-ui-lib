---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="Your Business — Professional Services">
  <!-- Hero -->
  <section class="hero">
    <div class="container hero-inner">
      <span class="badge">Trusted by 500+ clients</span>
      <h1>Headline that speaks to your customer's need</h1>
      <p class="hero-sub">
        A single sentence that explains what you do, who it's for, and why it
        matters. Keep it under 20 words.
      </p>
      <div class="hero-actions">
        <a href="#contact" class="btn btn-primary">Get a Quote</a>
        <a href="#services" class="btn btn-secondary">Our Services</a>
      </div>
    </div>
  </section>

  <!-- Services -->
  <section id="services" class="section section-alt">
    <div class="container">
      <h2>What we do</h2>
      <p class="section-lead">
        Brief description of your service categories. Two sentences maximum.
      </p>
      <div class="features-grid">
        <div class="card">
          <h3>Service One</h3>
          <p>
            Describe this service in one or two sentences. Focus on the benefit
            to the customer, not the technical details.
          </p>
        </div>
        <div class="card">
          <h3>Service Two</h3>
          <p>
            Describe this service in one or two sentences. Focus on the benefit
            to the customer, not the technical details.
          </p>
        </div>
        <div class="card">
          <h3>Service Three</h3>
          <p>
            Describe this service in one or two sentences. Focus on the benefit
            to the customer, not the technical details.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Social proof -->
  <section id="about" class="section">
    <div class="container proof-inner">
      <h2>Why clients choose us</h2>
      <p class="section-lead">
        A short paragraph about your track record, approach, or differentiator.
      </p>
      <div class="stats-row">
        <div class="stat">
          <span class="stat-number">500+</span>
          <span class="stat-label">Clients served</span>
        </div>
        <div class="stat">
          <span class="stat-number">10+</span>
          <span class="stat-label">Years experience</span>
        </div>
        <div class="stat">
          <span class="stat-number">4.9</span>
          <span class="stat-label">Average rating</span>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section id="contact" class="section section-alt">
    <div class="container cta-inner">
      <h2>Ready to get started?</h2>
      <p>
        One sentence that creates urgency or removes friction. Example: "Get a
        free consultation — no commitment required."
      </p>
      <a href="mailto:hello@example.com" class="btn btn-primary">Contact Us</a>
    </div>
  </section>
</BaseLayout>

<style>
  /* Hero */
  .hero {
    padding-block: var(--spacing-12) var(--spacing-16);
    background-color: var(--color-background);
  }

  @media (min-width: 1024px) {
    .hero {
      padding-block: var(--spacing-20);
    }
  }

  .hero-inner {
    max-width: 800px;
  }

  .hero h1 {
    margin: var(--spacing-4) 0 var(--spacing-4);
  }

  @media (min-width: 1024px) {
    .hero h1 {
      font-size: var(--text-5xl);
      line-height: 1.1;
    }
  }

  .hero-sub {
    font-size: var(--text-lg);
    margin-bottom: var(--spacing-8);
  }

  .hero-actions {
    display: flex;
    flex-wrap: wrap;
    gap: var(--spacing-3);
  }

  /* Section lead text */
  .section-lead {
    font-size: var(--text-lg);
    margin-bottom: var(--spacing-10);
  }

  /* Features grid */
  .features-grid {
    display: grid;
    gap: var(--spacing-4);
  }

  @media (min-width: 640px) {
    .features-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (min-width: 1024px) {
    .features-grid {
      grid-template-columns: repeat(3, 1fr);
      gap: var(--spacing-6);
    }
  }

  .features-grid h3 {
    margin: 0 0 var(--spacing-2);
  }

  .features-grid p {
    margin: 0;
    font-size: var(--text-sm);
  }

  /* Stats */
  .stats-row {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--spacing-6);
    margin-top: var(--spacing-10);
    text-align: center;
  }

  .stat-number {
    display: block;
    font-family: var(--font-display);
    font-size: var(--text-4xl);
    font-weight: 700;
    color: var(--color-primary);
  }

  .stat-label {
    display: block;
    font-size: var(--text-sm);
    color: var(--color-on-surface-muted);
    margin-top: var(--spacing-1);
  }

  /* CTA section */
  .cta-inner {
    text-align: center;
    max-width: 600px;
  }

  .cta-inner h2 {
    margin-bottom: var(--spacing-4);
  }

  .cta-inner p {
    margin-inline: auto;
    margin-bottom: var(--spacing-8);
  }
</style>
